---
import '../../style.css';
import Navbar from '../../components/Navbar.astro';
import productsData from '../../data/products.json';
import logoImg from '../../assets/logo-transparent.png';

// Static path generation for each product
export function getStaticPaths() {
  return productsData.map(product => ({
    params: { id: product.id },
    props: { product }
  }));
}

const { product } = Astro.props;

// Image map (mirrors ProductGrid.vue logic)
const imageAssets = {
  "../assets/hoodie_black.png": "/src/assets/hoodie_black.png",
  "../assets/tshirt_white.png": "/src/assets/tshirt_white.png",
  "../assets/backpack_grey.png": "/src/assets/backpack_grey.png",
  "../assets/totebag_canvas.png": "/src/assets/totebag_canvas.png",
};

// Build WhatsApp link helper
function buildWALink(p: any, size: string, color: string) {
  const msg = `Bonjour Modilo, je souhaite commander :\n• ${p.title} – Taille : ${size}${color ? ', Couleur : ' + color : ''} – ${p.price} MAD\n\nMerci de confirmer ma commande.`;
  return `https://wa.me/+212630257293?text=${encodeURIComponent(msg)}`;
}

// Category label
const catLabel = product.category === 'hoodie' ? 'Sweat à Capuche' : 'T-Shirt';
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{product.title} – Modilo</title>
    <meta name="description" content={product.description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar activePage="products" />

    <main class="product-page">
      <!-- Breadcrumb -->
      <div class="breadcrumb-bar">
        <div class="container">
          <nav class="breadcrumb">
            <a href="/">Accueil</a>
            <span class="sep">›</span>
            <a href="/products">Boutique</a>
            <span class="sep">›</span>
            <span class="current">{product.title}</span>
          </nav>
        </div>
      </div>

      <div class="container">
        <div class="product-layout">

          <!-- Left: Image Gallery -->
          <div class="gallery-pane">
            <div class="main-image-box" id="main-img-box">
              <img
                id="main-product-img"
                src={imageAssets[product.image] || product.image}
                alt={product.title}
                style={product.cssFilter ? `filter: ${product.cssFilter}` : ''}
                class="main-product-img"
              />
            </div>
            {product.images && product.images.length > 1 && (
              <div class="thumb-row">
                {product.images.map((img, i) => (
                  <button class={`thumb-btn${i === 0 ? ' active' : ''}`} data-img={imageAssets[img] || img} data-filter={product.cssFilter || ''}>
                    <img src={imageAssets[img] || img} alt={`Vue ${i+1}`} style={product.cssFilter ? `filter: ${product.cssFilter}` : ''} />
                  </button>
                ))}
              </div>
            )}
          </div>

          <!-- Right: Product Info -->
          <div class="info-pane">
            <span class="product-cat-label">{catLabel}</span>
            <h1 class="product-name">{product.title}</h1>
            <p class="product-price">{product.price} <span class="price-currency">MAD</span></p>

            <div class="info-divider"></div>

            <!-- Size selector -->
            {product.variations?.sizes && (
              <div class="selector-group" id="size-group">
                <div class="selector-label-row">
                  <span class="selector-label">Taille</span>
                  <span class="size-guide-link">Guide des tailles</span>
                </div>
                <div class="size-options" id="size-options">
                  {product.variations.sizes.map((size, i) => (
                    <button
                      class={`size-btn${i === 0 ? ' active' : ''}`}
                      data-size={size}
                      id={`size-${size}`}
                    >
                      {size}
                    </button>
                  ))}
                </div>
              </div>
            )}

            <!-- Color selector -->
            {product.variations?.colors && (
              <div class="selector-group" id="color-group">
                <span class="selector-label">Couleur — <span class="selected-color-label" id="selected-color-label">{product.variations.colors[0]}</span></span>
                <div class="color-options" id="color-options">
                  {product.variations.colors.map((color, i) => (
                    <button
                      class={`color-btn${i === 0 ? ' active' : ''}`}
                      data-color={color}
                      id={`color-${color.replace(/\s/g,'-')}`}
                    >
                      {color}
                    </button>
                  ))}
                </div>
              </div>
            )}

            <div class="info-divider"></div>

            <!-- Action buttons -->
            <div class="action-row">
              <button class="btn-add-cart" id="add-cart-btn">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle>
                  <circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                Ajouter au Panier
              </button>

              <a href="#" class="btn-order-wa" id="order-wa-btn" target="_blank">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
                  <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.233-1.371a9.936 9.936 0 0 0 4.779 1.21h.005c5.505 0 9.988-4.479 9.989-9.986 0-2.67-1.037-5.178-2.922-7.062A9.925 9.925 0 0 0 12.012 2z"/>
                </svg>
                Commander via WhatsApp
              </a>
            </div>

            <!-- Trust badges -->
            <div class="trust-badges">
              <div class="trust-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Paiement à la livraison</span>
              </div>
              <div class="trust-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                <span>Livraison dans tout le Maroc</span>
              </div>
              <div class="trust-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                <span>Qualité premium garantie</span>
              </div>
            </div>

            <div class="info-divider"></div>

            <!-- Description -->
            <div class="desc-block">
              <h3 class="desc-heading">Description</h3>
              <p class="desc-text">{product.description}</p>
            </div>

            <!-- Specifications -->
            {product.specifications && product.specifications.length > 0 && (
              <div class="specs-block">
                <h3 class="desc-heading">Détails du produit</h3>
                <table class="specs-table">
                  <tbody>
                    {product.specifications.map(spec => (
                      <tr>
                        <td class="spec-name">{spec.name}</td>
                        <td class="spec-val">{spec.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <img src={logoImg.src} alt="Modilo Logo" class="footer-logo" />
            <p class="footer-desc">Vêtements de caractère et accessoires urbains haut de gamme.</p>
          </div>
          <div class="footer-links">
            <h4>Navigation</h4>
            <a href="/products">Boutique</a>
            <a href="/custom">Impression Perso</a>
            <a href="/delivery">Livraison</a>
          </div>
          <div class="footer-contact">
            <h4>Contact Direct</h4>
            <a href="https://wa.me/+212630257293" target="_blank" class="footer-whatsapp">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.233-1.371a9.936 9.936 0 0 0 4.779 1.21h.005c5.505 0 9.988-4.479 9.989-9.986 0-2.67-1.037-5.178-2.922-7.062A9.925 9.925 0 0 0 12.012 2z"/></svg>
              Discuter sur WhatsApp
            </a>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Modilo. Tous droits réservés.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<script define:vars={{ product }}>
  // Image map (client-side for resolving bundled assets)
  const imageMap = {
    "../assets/hoodie_black.png": null,
    "../assets/tshirt_white.png": null,
    "../assets/backpack_grey.png": null,
    "../assets/totebag_canvas.png": null,
  };

  let selectedSize = product.variations?.sizes?.[0] || '';
  let selectedColor = product.variations?.colors?.[0] || '';

  // Size buttons
  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedSize = btn.dataset.size;
      updateWALink();
    });
  });

  // Color buttons
  document.querySelectorAll('.color-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedColor = btn.dataset.color;
      const label = document.getElementById('selected-color-label');
      if (label) label.textContent = selectedColor;
      updateWALink();
    });
  });

  // Thumbnail gallery
  document.querySelectorAll('.thumb-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const mainImg = document.getElementById('main-product-img');
      if (mainImg) {
        mainImg.src = btn.dataset.img;
        mainImg.style.filter = btn.dataset.filter || '';
      }
    });
  });

  // WhatsApp link updater
  function buildLink() {
    const msg = `Bonjour Modilo, je souhaite commander :\n• ${product.title} – Taille : ${selectedSize}${selectedColor ? ', Couleur : ' + selectedColor : ''} – ${product.price} MAD\n\nMerci de confirmer ma commande.`;
    return `https://wa.me/+212630257293?text=${encodeURIComponent(msg)}`;
  }

  function updateWALink() {
    const waBtn = document.getElementById('order-wa-btn');
    if (waBtn) waBtn.href = buildLink();
  }

  // Add to cart
  document.getElementById('add-cart-btn')?.addEventListener('click', () => {
    const cart = JSON.parse(localStorage.getItem('modilo_cart') || '[]');
    const existing = cart.find(i => i.id === product.id && i.size === selectedSize && i.color === selectedColor);
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push({
        id: product.id,
        title: product.title,
        price: product.price,
        size: selectedSize,
        color: selectedColor,
        quantity: 1,
        image: product.image,
        cssFilter: product.cssFilter || null
      });
    }
    localStorage.setItem('modilo_cart', JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart-updated'));
    window.location.href = '/cart';
  });

  // Initialize WA link
  updateWALink();
</script>

<style>
  .product-page {
    min-height: 80vh;
    background: var(--bg-primary);
    padding-bottom: 80px;
    padding-top: 100px;
  }

  .breadcrumb-bar {
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--card-border);
    padding: 14px 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--text-primary); }
  .breadcrumb .sep { color: var(--card-border); }
  .breadcrumb .current { color: var(--text-primary); font-weight: 500; }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Layout ─────────────────────── */
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    padding: 56px 0;
    align-items: start;
  }

  @media (max-width: 900px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 36px 0;
    }
  }

  /* ── Gallery ─────────────────────── */
  .gallery-pane {
    position: sticky;
    top: 90px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (max-width: 900px) {
    .gallery-pane { position: static; }
  }

  .main-image-box {
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .main-product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .main-image-box:hover .main-product-img {
    transform: scale(1.03);
  }

  .thumb-row {
    display: flex;
    gap: 10px;
  }

  .thumb-btn {
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid var(--card-border);
    cursor: pointer;
    padding: 0;
    background: var(--bg-secondary);
    transition: border-color 0.2s;
    flex-shrink: 0;
  }

  .thumb-btn.active,
  .thumb-btn:hover {
    border-color: var(--accent-primary);
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Info Pane ─────────────────── */
  .info-pane {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 8px;
  }

  .product-cat-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--text-muted);
    font-weight: 600;
    margin-bottom: 10px;
    display: block;
  }

  .product-name {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.15;
    margin-bottom: 14px;
  }

  @media (max-width: 600px) {
    .product-name { font-size: 1.7rem; }
  }

  .product-price {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 0;
    line-height: 1;
  }

  .price-currency {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-left: 4px;
  }

  .info-divider {
    height: 1px;
    background: var(--card-border);
    margin: 24px 0;
  }

  /* ── Selectors ─────────────────── */
  .selector-group {
    margin-bottom: 20px;
  }

  .selector-label-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .selector-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.3px;
    display: block;
    margin-bottom: 12px;
  }

  .selector-label-row .selector-label {
    margin-bottom: 0;
  }

  .size-guide-link {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: underline;
    cursor: pointer;
  }

  .size-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .size-btn {
    min-width: 48px;
    height: 48px;
    padding: 0 14px;
    border: 1.5px solid var(--card-border);
    border-radius: 8px;
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .size-btn:hover {
    border-color: var(--text-primary);
  }

  .size-btn.active {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    color: #ffffff;
  }

  .color-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .color-btn {
    padding: 8px 16px;
    border: 1.5px solid var(--card-border);
    border-radius: 99px;
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
  }

  .color-btn:hover {
    border-color: var(--text-primary);
    color: var(--text-primary);
  }

  .color-btn.active {
    background: var(--accent-primary);
    border-color: var(--accent-primary);
    color: #ffffff;
  }

  .selected-color-label {
    font-weight: 400;
    color: var(--text-secondary);
  }

  /* ── Action Buttons ─────────────── */
  .action-row {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .btn-add-cart {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--accent-primary);
    color: #ffffff;
    border: none;
    padding: 17px 28px;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }

  .btn-add-cart:hover {
    background: var(--accent-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  .btn-order-wa {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #25d366;
    color: #ffffff;
    text-decoration: none;
    padding: 17px 28px;
    border-radius: 12px;
    font-size: 0.95rem;
    font-weight: 700;
    transition: all 0.2s;
    letter-spacing: 0.3px;
  }

  .btn-order-wa:hover {
    background: #20ba59;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(37,211,102,0.2);
  }

  /* ── Trust Badges ───────────────── */
  .trust-badges {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 20px;
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  .trust-badge svg {
    color: var(--text-primary);
    flex-shrink: 0;
  }

  /* ── Description & Specs ────────── */
  .desc-block, .specs-block {
    margin-bottom: 24px;
  }

  .desc-heading {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
    letter-spacing: 0.2px;
  }

  .desc-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  .specs-table {
    width: 100%;
    border-collapse: collapse;
  }

  .specs-table tr {
    border-bottom: 1px solid var(--card-border);
  }

  .specs-table tr:last-child {
    border-bottom: none;
  }

  .spec-name {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 600;
    padding: 10px 0;
    width: 45%;
  }

  .spec-val {
    font-size: 0.85rem;
    color: var(--text-primary);
    font-weight: 500;
    padding: 10px 0;
  }

  /* ── Footer ─────────────────────── */
  .footer {
    background: #0d0c12;
    color: #ffffff;
    padding: 60px 0 32px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 50px;
    margin-bottom: 48px;
  }

  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr; gap: 30px; }
  }

  .footer-logo { height: 44px; object-fit: contain; }

  .footer-desc {
    color: #9a98a6;
    font-size: 0.88rem;
    line-height: 1.6;
    margin-top: 14px;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links h4, .footer-contact h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 4px;
    font-family: var(--font-heading);
  }

  .footer-links a {
    color: #9a98a6;
    text-decoration: none;
    font-size: 0.88rem;
    transition: color 0.2s;
  }

  .footer-links a:hover { color: #F1E6D3; }

  .footer-contact { display: flex; flex-direction: column; gap: 14px; }

  .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    background: #25d366;
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    padding: 11px 20px;
    border-radius: 99px;
    font-size: 0.85rem;
    transition: all 0.2s;
  }

  .footer-whatsapp:hover {
    background: #20ba59;
    transform: translateY(-1px);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 28px;
  }

  .footer-bottom p {
    color: #6a6875;
    font-size: 0.82rem;
  }
</style>
