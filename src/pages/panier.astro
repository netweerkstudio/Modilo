---
import Layout from '../layouts/Layout.astro';
import CartPage from '../components/CartPage.vue';
---

<Layout 
  title="Modilo - Mon Panier" 
  description="Gérez votre panier et passez votre commande via WhatsApp en un seul clic."
  activePage="cart"
>
  <main class="cart-main-content">
    <CartPage client:load />
  </main>
</Layout>

<style>
  .cart-main-content {
    background-color: var(--bg-primary);
    min-height: 80vh;
    padding-top: 80px;
  }
</style>
