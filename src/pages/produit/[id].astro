---
import Layout from '../../layouts/Layout.astro';
import productsData from '../../data/products.json';

// Static path generation for each product
export function getStaticPaths() {
  return productsData.map(product => ({
    params: { id: product.id },
    props: { product }
  }));
}

const { product } = Astro.props;

// Image map (mirrors ProductGrid.vue logic)
const imageAssets = {
  "../assets/hoodie_black.png": "/src/assets/hoodie_black.png",
  "../assets/tshirt_white.png": "/src/assets/tshirt_white.png",
  "../assets/backpack_grey.png": "/src/assets/backpack_grey.png",
  "../assets/totebag_canvas.png": "/src/assets/totebag_canvas.png",
};

// Build WhatsApp link helper
function buildWALink(p: any, size: string, color: string) {
  const msg = `Bonjour Modilo, je souhaite commander :\n• ${p.title} – Taille : ${size}${color ? ', Couleur : ' + color : ''} – ${p.price} MAD\n\nMerci de confirmer ma commande.`;
  return `https://wa.me/+212630257293?text=${encodeURIComponent(msg)}`;
}

// Category label
const catLabel = product.category === 'hoodie' ? 'Sweat à Capuche' : 'T-Shirt';
---

<Layout 
  title={`${product.title} – Modilo`}
  description={product.description}
  activePage="products"
>

    <main class="product-page">
      <!-- Breadcrumb -->
      <div class="breadcrumb-bar">
        <div class="container">
          <nav class="breadcrumb">
            <a href="/">Accueil</a>
            <span class="sep">›</span>
            <a href="/produits">Boutique</a>
            <span class="sep">›</span>
            <span class="current">{product.title}</span>
          </nav>
        </div>
      </div>

      <div class="container">
        <div class="product-layout">

          <!-- Left: Image Gallery -->
          <div class="gallery-pane">
            {product.images && product.images.length > 1 && (
              <div class="thumb-col">
                {product.images.map((img, i) => (
                  <button class={`thumb-btn${i === 0 ? ' active' : ''}`} data-img={imageAssets[img] || img}>
                    <img src={imageAssets[img] || img} alt={`Vue ${i+1}`} />
                  </button>
                ))}
              </div>
            )}
            <div class="main-image-box" id="main-img-box">
              <img
                id="main-product-img"
                src={imageAssets[product.image] || product.image}
                alt={product.title}
                class="main-product-img"
              />
            </div>
          </div> 

          <!-- Right: Product Info -->
          <div class="info-pane">
            <span class="product-cat-label">{catLabel}</span>
            <h1 class="product-name">{product.title}</h1>
            <div class="price-share-row">
              <p class="product-price">{product.price} <span class="price-currency">MAD</span></p>
              <button class="btn-share" id="share-btn" aria-label="Partager ce produit">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"></path>
                  <polyline points="16 6 12 2 8 6"></polyline>
                  <line x1="12" y1="2" x2="12" y2="15"></line>
                </svg>
                <span>Partager</span>
              </button>
            </div>

            <div class="info-divider"></div>

            <!-- Size selector -->
            {product.variations?.sizes && (
              <div class="selector-group" id="size-group">
                <span class="selector-label">Taille</span>
                <div class="size-options" id="size-options">
                  {product.variations.sizes.map((size, i) => (
                    <button
                      class={`size-btn${i === 0 ? ' active' : ''}`}
                      data-size={size}
                      id={`size-${size}`}
                    >
                      {size}
                    </button>
                  ))}
                </div>
              </div>
            )}

            <!-- Color selector -->
            {product.variations?.colors && (
              <div class="selector-group" id="color-group">
                <span class="selector-label">Couleur — <span class="selected-color-label" id="selected-color-label">{product.variations.colors[0]}</span></span>
                <div class="color-options" id="color-options">
                  {product.variations.colors.map((color, i) => (
                    <button
                      class={`color-btn${i === 0 ? ' active' : ''}`}
                      data-color={color}
                      id={`color-${color.replace(/\s/g,'-')}`}
                    >
                      {color}
                    </button>
                  ))}
                </div>
              </div>
            )}

            <div class="info-divider"></div>  

            <div class="action-row-buttons">
              <button class="btn-order-now-top" id="order-now-btn">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Commander
              </button>

              <button class="btn-add-cart-top" id="add-cart-btn">
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="9" cy="21" r="1"></circle>
                  <circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                Ajouter au Panier
              </button>
            </div>

            <!-- Trust badges -->
            <div class="trust-badges">
              <div class="trust-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>Paiement à la livraison</span>
              </div>
              <div class="trust-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                <span>Livraison dans tout le Maroc</span>
              </div>
              <div class="trust-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
                <span>Qualité premium garantie</span>
              </div>
            </div>

            <div class="info-divider"></div>

            <!-- Description -->
            <div class="desc-block">
              <h3 class="desc-heading">Description</h3>
              <p class="desc-text">{product.description}</p>
            </div>

            <!-- Specifications -->
            {product.specifications && product.specifications.length > 0 && (
              <div class="specs-block">
                <h3 class="desc-heading">Détails du produit</h3>
                <table class="specs-table">
                  <tbody>
                    {product.specifications.map(spec => (
                      <tr>
                        <td class="spec-name">{spec.name}</td>
                        <td class="spec-val">{spec.value}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </div>

        <!-- Commande Rapide Form Section -->
        <div class="product-delivery-section"> 
          <div class="product-delivery-card"> 
            <div class="delivery-card-header">
              <div class="delivery-title-badge">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
                Commande Instantanée
              </div>
              <h3 class="delivery-title">Achat Express — Commande Rapide</h3>
              <p class="delivery-subtitle">Pas d'inscription requise. Remplissez simplement vos informations ci-dessous pour finaliser votre commande directement sur WhatsApp. Paiement à la livraison.</p>
            </div>

            <!-- Order summary preview inside card -->
            <div class="quick-order-preview">
              <div class="preview-img-wrapper">
                <img src={product.image} alt={product.title} id="quick-preview-img" />
              </div>
              <div class="preview-details">
                <span class="preview-name">{product.title}</span>
                <span class="preview-meta">
                  Taille : <span id="quick-preview-size">-</span>
                  {product.variations?.colors && (
                    <span id="quick-preview-color-wrapper"> — Couleur : <span id="quick-preview-color">-</span></span>
                  )}
                </span>
              </div>
              <div class="preview-price-qty">
                <span class="preview-price">{product.price} MAD</span>
              </div>
            </div>
            
            <div class="form-grid">
              <div class="form-group">
                <label for="p-fullname" class="form-label">Nom Complet *</label>
                <div class="input-icon-wrapper">
                  <svg class="input-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                  <input 
                    type="text" 
                    id="p-fullname" 
                    class="form-input has-icon" 
                    placeholder="Ex: Mohammed Alami" 
                  />
                </div>
                <span class="error-text" id="error-name" style="display: none;"></span>
              </div>

              <div class="form-group">
                <label for="p-phone" class="form-label">Téléphone *</label>
                <div class="input-icon-wrapper">
                  <svg class="input-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                  <input 
                    type="tel" 
                    id="p-phone" 
                    class="form-input has-icon" 
                    placeholder="Ex: 0612345678" 
                  />
                </div>
                <span class="error-text" id="error-phone" style="display: none;"></span>
              </div>

              <div class="form-group" id="p-city-group">
                <label for="p-city-select" class="form-label">Ville *</label>
                <div class="input-icon-wrapper">
                  <svg class="input-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                  <select id="p-city-select" class="form-select has-icon">
                    <option value="tanger">Tanger (Livraison Gratuite)</option>
                    <option value="autre">Autre ville du Maroc (Livraison: 45 MAD)</option>
                  </select>
                </div>
              </div>

              <div class="form-group" id="p-custom-city-group" style="display: none;">
                <label for="p-custom-city" class="form-label">Nom de la ville *</label>
                <div class="input-icon-wrapper">
                  <svg class="input-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                  <input 
                    type="text" 
                    id="p-custom-city" 
                    class="form-input has-icon" 
                    placeholder="Ex: Casablanca, Rabat..." 
                  />
                </div>
                <span class="error-text" id="error-city" style="display: none;"></span>
              </div>
            </div>

            <div class="form-group">
              <label for="p-address" class="form-label">Adresse de livraison *</label>
              <div class="input-icon-wrapper">
                <svg class="input-icon" style="top: 14px;" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                  <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                <textarea 
                  id="p-address" 
                  class="form-input has-icon" 
                  placeholder="Ex: Boulevard Mohamed V, N° 134, Appt 4" 
                  rows="2"
                  style="min-height: 80px;"
                ></textarea>
              </div>
              <span class="error-text" id="error-address" style="display: none;"></span>
            </div>

            <button class="btn-order-wa" id="order-wa-btn" style="width: 100%; border: none; cursor: pointer;">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                <path d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.233-1.371a9.936 9.936 0 0 0 4.779 1.21h.005c5.505 0 9.988-4.479 9.989-9.986 0-2.67-1.037-5.178-2.922-7.062A9.925 9.925 0 0 0 12.012 2zm5.835 14.165c-.32.9-.1.9-.1.9s-.427 1.099-1.637 1.328c-1.21.23-2.56.096-4.576-.718-2.016-.814-3.526-2.585-4.464-3.878-.938-1.293-1.579-2.738-1.579-4.22 0-1.48.718-2.203 1.026-2.502.308-.299.82-.455 1.077-.455.257 0 .492-.01.705.01.214.02.487-.08.761.564.274.645.94 2.274 1.017 2.43.077.157.12.338.017.532-.102.193-.154.314-.308.492-.154.177-.325.298-.462.46-.153.18-.316.378-.137.684.18.307.8 1.314 1.718 2.128.918.814 1.692 1.065 1.992 1.185.3.12.478.105.658-.1.18-.206.77-.895.974-1.2.206-.307.41-.258.693-.153.282.105 1.795.847 2.103.992.308.145.513.218.59.35.077.133.077.77-.243 1.67z"/>
              </svg>
              Commander via WhatsApp
            </button>
          </div>
        </div>
      </div> 
    </main>

</Layout>



<script define:vars={{ product }}>
  // Image map (client-side for resolving bundled assets)
  const imageMap = {
    "../assets/hoodie_black.png": null,
    "../assets/tshirt_white.png": null,
    "../assets/backpack_grey.png": null,
    "../assets/totebag_canvas.png": null,
  };

  let selectedSize = product.variations?.sizes?.[0] || '';
  let selectedColor = product.variations?.colors?.[0] || '';

  function updateQuickPreview() {
    const sizeEl = document.getElementById('quick-preview-size');
    if (sizeEl) sizeEl.textContent = selectedSize || 'Non sélectionnée';

    const colorEl = document.getElementById('quick-preview-color');
    if (colorEl) colorEl.textContent = selectedColor || 'Non sélectionnée';
  }

  // Initialize preview
  updateQuickPreview();

  // Load customer details from localStorage
  const fullnameInput = document.getElementById('p-fullname');
  const phoneInput = document.getElementById('p-phone');
  const citySelect = document.getElementById('p-city-select');
  const cityGroup = document.getElementById('p-city-group');
  const customCityGroup = document.getElementById('p-custom-city-group');
  const customCityInput = document.getElementById('p-custom-city');
  const addressInput = document.getElementById('p-address');

  function updateCityFieldWidth() {
    if (!citySelect || !cityGroup) return;
    if (citySelect.value === 'tanger') {
      cityGroup.classList.add('full-width');
    } else {
      cityGroup.classList.remove('full-width');
    }
  }

  if (fullnameInput) fullnameInput.value = localStorage.getItem('modilo_cust_name') || '';
  if (phoneInput) phoneInput.value = localStorage.getItem('modilo_cust_phone') || '';
  if (citySelect) {
    citySelect.value = localStorage.getItem('modilo_cust_city_type') || 'tanger';
    if (citySelect.value === 'autre' && customCityGroup) {
      customCityGroup.style.display = 'block';
    }
    updateCityFieldWidth();
  }
  if (customCityInput) customCityInput.value = localStorage.getItem('modilo_cust_city_custom') || '';
  if (addressInput) addressInput.value = localStorage.getItem('modilo_cust_address') || '';

  // Save changes to localStorage on input
  function saveCustomerInfo() {
    if (fullnameInput) localStorage.setItem('modilo_cust_name', fullnameInput.value);
    if (phoneInput) localStorage.setItem('modilo_cust_phone', phoneInput.value);
    if (citySelect) localStorage.setItem('modilo_cust_city_type', citySelect.value);
    if (customCityInput) localStorage.setItem('modilo_cust_city_custom', customCityInput.value);
    if (addressInput) localStorage.setItem('modilo_cust_address', addressInput.value);
  }

  [fullnameInput, phoneInput, customCityInput, addressInput].forEach(input => {
    input?.addEventListener('input', () => {
      saveCustomerInfo();
      // Hide error text when user starts typing
      const errorSpan = input.nextElementSibling;
      if (errorSpan && errorSpan.classList.contains('error-text')) {
        errorSpan.style.display = 'none';
      }
    });
  }); 

  citySelect?.addEventListener('change', () => {
    saveCustomerInfo();
    updateCityFieldWidth();
    if (citySelect.value === 'autre') {
      if (customCityGroup) customCityGroup.style.display = 'block';
    } else {
      if (customCityGroup) customCityGroup.style.display = 'none';
      const errorCity = document.getElementById('error-city');
      if (errorCity) errorCity.style.display = 'none';
    }
  });

  // Size buttons
  document.querySelectorAll('.size-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.size-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedSize = btn.dataset.size;
      updateQuickPreview();
    });
  });

  // Color buttons
  document.querySelectorAll('.color-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedColor = btn.dataset.color;
      const label = document.getElementById('selected-color-label');
      if (label) label.textContent = selectedColor;
      updateQuickPreview();
    });
  });

  // Thumbnail gallery
  document.querySelectorAll('.thumb-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.thumb-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const mainImg = document.getElementById('main-product-img');
      if (mainImg) {
        mainImg.src = btn.dataset.img;
      }
    });
  });

  // Validation function
  function validateForm() {
    let isValid = true;
    
    // Reset errors
    ['error-name', 'error-phone', 'error-city', 'error-address'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.style.display = 'none';
    });

    if (!fullnameInput.value.trim()) {
      const el = document.getElementById('error-name');
      if (el) {
        el.textContent = 'Veuillez saisir votre nom complet.';
        el.style.display = 'block';
      }
      isValid = false;
    }

    const trimmedPhone = phoneInput.value.trim().replace(/\s/g, '');
    if (!trimmedPhone) {
      const el = document.getElementById('error-phone');
      if (el) {
        el.textContent = 'Veuillez saisir votre numéro de téléphone.';
        el.style.display = 'block';
      }
      isValid = false;
    } else if (!/^(?:\+212|0)[5-7]\d{8}$/.test(trimmedPhone)) {
      const el = document.getElementById('error-phone');
      if (el) {
        el.textContent = 'Veuillez saisir un numéro de téléphone marocain valide (ex: 0612345678).';
        el.style.display = 'block';
      }
      isValid = false;
    }

    if (citySelect.value === 'autre' && !customCityInput.value.trim()) {
      const el = document.getElementById('error-city');
      if (el) {
        el.textContent = 'Veuillez saisir le nom de votre ville.';
        el.style.display = 'block';
      }
      isValid = false;
    }

    if (!addressInput.value.trim()) {
      const el = document.getElementById('error-address');
      if (el) {
        el.textContent = 'Veuillez saisir votre adresse de livraison.';
        el.style.display = 'block';
      }
      isValid = false;
    }

    return isValid;
  }

  // Order via WhatsApp (Direct single product fast order)
  document.getElementById('order-wa-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    if (!validateForm()) {
      const firstError = document.querySelector('.error-text[style*="block"]');
      if (firstError) {
        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
      return;
    }

    const finalCity = citySelect.value === 'tanger' ? 'Tanger' : customCityInput.value.trim();
    const shippingText = citySelect.value === 'tanger' ? 'Gratuite' : '45 MAD';
    const shippingCost = citySelect.value === 'tanger' ? 0 : 45;
    const grandTotal = Number(product.price) + shippingCost;

    let message = `Bonjour Modilo, je souhaite commander l'article suivant :\n\n`;
    message += `• 1x ${product.title} (Taille: ${selectedSize}${selectedColor ? ', Couleur: ' + selectedColor : ''}) - ${product.price} MAD\n\n`;
    message += `Sous-total : ${product.price} MAD\n`;
    message += `Frais de livraison : ${shippingText}\n`;
    message += `Total : ${grandTotal} MAD\n\n`;
    message += `*Informations de livraison :*\n`;
    message += `• *Nom complet :* ${fullnameInput.value.trim()}\n`;
    message += `• *Téléphone :* ${phoneInput.value.trim()}\n`;
    message += `• *Ville :* ${finalCity}\n`;
    message += `• *Adresse :* ${addressInput.value.trim()}\n\n`;
    message += `Merci de valider ma commande.`;

    const link = `https://wa.me/+212630257293?text=${encodeURIComponent(message)}`;
    window.open(link, '_blank');
  });

  // Add to cart and redirect to cart page
  document.getElementById('add-cart-btn')?.addEventListener('click', () => {
    const cart = JSON.parse(localStorage.getItem('modilo_cart') || '[]');
    const existing = cart.find(i => i.id === product.id && i.size === selectedSize && i.color === selectedColor);
    if (existing) {
      existing.quantity += 1;
    } else {
      cart.push({
        id: product.id,
        title: product.title,
        price: product.price,
        size: selectedSize,
        color: selectedColor,
        quantity: 1,
        image: product.image
      });
    }
    localStorage.setItem('modilo_cart', JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart-updated'));
    window.location.href = '/panier';
  });

  // Share button logic
  const shareBtn = document.getElementById('share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = {
        title: document.title,
        text: `Découvrez le produit ${product.title} chez Modilo !`,
        url: window.location.href
      };

      if (navigator.share && navigator.canShare && navigator.canShare(shareData)) {
        try {
          await navigator.share(shareData);
          return;
        } catch (err) {
          console.log('Share canceled or failed', err);
        }
      }

      // Fallback: Copy link
      let copied = false;
      const textToCopy = window.location.href;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        try {
          await navigator.clipboard.writeText(textToCopy);
          copied = true;
        } catch (err) {
          console.error('navigator.clipboard failed', err);
        }
      }

      if (!copied) {
        try {
          const textArea = document.createElement('textarea');
          textArea.value = textToCopy;
          textArea.style.position = 'fixed';
          textArea.style.top = '0';
          textArea.style.left = '0';
          textArea.style.width = '2em';
          textArea.style.height = '2em';
          textArea.style.padding = '0';
          textArea.style.border = 'none';
          textArea.style.outline = 'none';
          textArea.style.boxShadow = 'none';
          textArea.style.background = 'transparent';
          document.body.appendChild(textArea);
          textArea.focus();
          textArea.select();
          copied = document.execCommand('copy');
          document.body.removeChild(textArea);
        } catch (err) {
          console.error('Fallback copy failed', err);
        }
      }

      if (copied) {
        const span = shareBtn.querySelector('span');
        if (span) {
          const originalText = span.textContent;
          span.textContent = 'Lien copié !';
          shareBtn.classList.add('copied');
          setTimeout(() => {
            span.textContent = originalText;
            shareBtn.classList.remove('copied');
          }, 2000);
        }
      }
    });
  }

  // Scroll to fast order form when clicking "Order now"
  document.getElementById('order-now-btn')?.addEventListener('click', (e) => {
    e.preventDefault();
    const formEl = document.querySelector('.product-delivery-section');
    if (formEl) {
      formEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
</script>

