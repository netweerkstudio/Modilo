---
import Layout from '../layouts/Layout.astro';
import ProductGrid from '../components/ProductGrid.vue';
import logoImg from '../assets/images/logo/logo-website.png';
import heroBgImg from '../assets/hero_old_money_hawkins.png';
import philosophyBgImg from '../assets/philosophy_bg.png';
import teamMember1 from '../assets/team_member_1.png';
import teamMember2 from '../assets/team_member_2.png';
import teamMember3 from '../assets/team_member_3.png';
---

<Layout 
  title="Modilo - Vestiaire Masculin de Caractère"
  description="Sweats à capuche lourds premium, t-shirts d'exception et accessoires exclusifs. Conçus exclusivement pour l'homme d'action."
  activePage="home"
  isTransparentOnScroll={true}
>

    <!-- Hero Section -->
    <section class="hero-section" style={`background-image: url('${heroBgImg.src || heroBgImg}')`}>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="hero-badge">Collection Été 2026</span>
        <h1 class="hero-title">L'Essentiel Élevé <span class="desktop-br"><br/></span>Pour Le Vestiaire Masculin</h1>
        <p class="hero-subtitle">
          Vêtements lourds d'exception et pièces d'ingénierie urbaine pour homme. Conçus pour affirmer votre prestance et durer toute une vie.
        </p>
        <div class="hero-actions">
          <a href="/products" class="btn-primary">Découvrir la Collection</a>
        </div>
        <div class="hero-scroll-hint"> 
          <span>Défiler</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <polyline points="19 12 12 19 5 12"></polyline>
          </svg>
        </div>
      </div>
    </section>

    <!-- Trust Strip -->
    <section class="trust-strip">
      <div class="container">
        <div class="trust-items">
          <div class="trust-item"> 
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
            <span>Livraison Partout au Maroc</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>Qualité Premium</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
            <span>Commande via WhatsApp</span>
          </div>
          <div class="trust-divider"></div>
          <div class="trust-item">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
            <span>Paiement à la Livraison</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Shop Section -->
    <section id="shop" class="shop-section">
      <ProductGrid client:load showOnlyFeatured={true} />
    </section>

    <!-- About Section -->
    <section id="about" class="about-section">
      <div class="container">
        <div class="about-grid">

          <!-- Left: Text -->
          <div class="about-text">
            <span class="section-subtitle">Notre Philosophie</span>
            <h2 class="about-title">L'Essence du<br/>Vestiaire Masculin.</h2>
            <p class="about-lead">
              Modilo a été fondé par trois jeunes ambitieux. Nous concevons, cousons et imprimons chaque vêtement avec amour pour vous offrir des pièces uniques et durables.
            </p>
            <p class="about-body">
              En proposant nos créations directement via WhatsApp, nous maintenons une relation de confiance, de proximité et ultra-réactive avec notre communauté.
            </p>

            <!-- Value pillars -->
            <div class="about-pillars">
              <div class="pillar">
                <div class="pillar-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <div>
                  <span class="pillar-title">Qualité Premium</span>
                  <p class="pillar-desc">Coton biologique 280–450 GSM, coutures renflanchées, finitions soignées.</p>
                </div>
              </div> 
              <div class="pillar">
                <div class="pillar-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                  <span class="pillar-title">Livraison Rapide</span>
                  <p class="pillar-desc">Commande via WhatsApp, livraison partout au Maroc sous 24–48h.</p>
                </div>
              </div>
              <div class="pillar">
                <div class="pillar-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                </div>
                <div>
                  <span class="pillar-title">Relation Directe</span>
                  <p class="pillar-desc">Pas d'intermédiaire — vous parlez directement à l'équipe qui crée vos pièces.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Image -->
          <div class="about-visual">
            <div class="about-img-box">
              <img src={philosophyBgImg.src || philosophyBgImg} alt="Artisanat Modilo" class="about-image" />
            </div>
            <div class="about-img-tag">
              <span>★★★★★</span>
              <p>100% fait avec passion</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Meet Our Team Section -->
    <section class="team-section">
      <div class="container">
        <div class="team-header">
          <span class="section-subtitle">Les Fondateurs</span>
          <h2 class="section-title">Notre Équipe</h2>
          <p class="team-intro">Trois amis, une vision. Modilo est né de notre passion commune pour le style masculin authentique et les pièces qui durent.</p>
          <div class="header-line"></div>
        </div>

        <div class="team-grid">
          <!-- Member 1 -->
          <div class="team-card">
            <div class="team-img-wrapper">
              <img src={teamMember1.src || teamMember1} alt="Co-fondateur Modilo" class="team-img" />
              <div class="team-img-overlay"></div>
            </div>
            <div class="team-card-body">
              <div class="team-name-row">
                <span class="team-name">Amin</span>
                <span class="team-role-badge">Co-Fondateur</span>
              </div>
            </div>
          </div>

          <!-- Member 2 (center, highlighted) -->
          <div class="team-card team-card--featured">
            <div class="team-featured-badge">Fondateur</div>
            <div class="team-img-wrapper">
              <img src={teamMember2.src || teamMember2} alt="Fondateur Modilo" class="team-img" />
              <div class="team-img-overlay"></div>
            </div>
            <div class="team-card-body">
              <div class="team-name-row">
                <span class="team-name">Reda</span>
                <span class="team-role-badge team-role-badge--dark">Fondateur</span>
              </div>
            </div>
          </div>

          <!-- Member 3 -->
          <div class="team-card">
            <div class="team-img-wrapper">
              <img src={teamMember3.src || teamMember3} alt="Co-fondateur Modilo" class="team-img" />
              <div class="team-img-overlay"></div>
            </div>
            <div class="team-card-body">
              <div class="team-name-row">
                <span class="team-name">Walid</span>
                <span class="team-role-badge">Co-Fondateur</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <!-- CTA Section -->
    <section class="cta-section"> 
      <div class="container">
        <div class="cta-box">

          <!-- Left -->
          <div class="cta-left">
            <span class="cta-label">Impression Personnalisée</span>
            <h2 class="cta-title">Votre Design.<br/>Notre Expertise.</h2>
            <div class="cta-chips">
              <span class="cta-chip">DTF & Sérigraphie</span>
              <span class="cta-chip">Logo &amp; Artwork</span>
              <span class="cta-chip">Petites séries</span>
            </div>
          </div>

          <!-- Right -->
          <div class="cta-right">
            <p class="cta-text">Imprimez vos créations sur nos pièces premium. Logo, artwork, texte — nous réalisons vos projets avec précision et dans les délais.</p>
            <div class="cta-actions">
              <a href="/custom" class="cta-btn-primary">
                Créer un Design Personnalisé
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left: 6px;">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>

</Layout>

<style>

  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    min-height: 100dvh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 150px 24px 80px;
  }

  .desktop-br {
    display: inline;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.72) 100%
    );
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 800px;
    width: 100%;
  }

  .hero-badge {
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 99px;
    margin-bottom: 24px;
    backdrop-filter: blur(6px);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 4.2rem;
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
    color: #ffffff;
  }

  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
    margin-bottom: 44px;
    max-width: 540px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 60px;
    width: 100%;
  }

  @media (max-width: 1024px) {
    .hero-title { font-size: 3rem; }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 130px;
      padding-bottom: 60px;
    }
    .desktop-br {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .hero-title { 
      font-size: 2.1rem; 
      letter-spacing: -0.5px; 
      line-height: 1.25;
      margin-bottom: 16px;
    }
    .hero-subtitle {
      font-size: 0.92rem;
      line-height: 1.6;
      margin-bottom: 32px;
      padding: 0 10px;
    }
    .hero-actions {
      flex-direction: column;
      gap: 12px;
      padding: 0 20px;
    }
  }

  .btn-primary, .btn-secondary {
    display: inline-block;
    padding: 16px 36px;
    border-radius: 99px;
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s ease;
    font-size: 0.95rem;
    letter-spacing: 0.3px;
  }

  .btn-primary {
    background-color: #F1E6D3;
    color: var(--text-primary);
  }

  .btn-primary:hover {
    background-color: #e8d8c0;
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
  }

  .hero-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.72rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* Trust Strip */
  .trust-strip {
    border-bottom: 1px solid var(--card-border);
    background: var(--bg-secondary);
  }

  .trust-items {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0;
    padding: 22px 0;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 32px;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.3px;
  }

  .trust-item svg {
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .trust-divider {
    width: 1px;
    height: 28px;
    background: var(--card-border);
  }

  @media (max-width: 768px) {
    .trust-items { gap: 12px 6px; }
    .trust-item { padding: 8px 12px; font-size: 0.8rem; }
    .trust-divider { display: none; }
  }

  @media (max-width: 600px) {
    .trust-items {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px 12px;
      padding: 24px 8px;
    }
    .trust-item {
      padding: 0;
      justify-content: center;
      text-align: center;
      font-size: 0.76rem;
      gap: 8px;
    }
    .trust-item svg {
      width: 18px;
      height: 18px;
    }
  }

  /* Container utility */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Section Intro Headers */
  .section-subtitle {
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 3px;
    color: var(--text-muted);
    font-weight: 600;
    display: block;
    margin-bottom: 12px;
  }
  
  .section-title {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.15;
  }
  
  .header-line {
    width: 40px;
    height: 3px;
    background: var(--accent-primary);
    margin: 18px auto 0;
    border-radius: 99px;
  }
  
  .header-line.left-align {
    margin: 18px 0 0;
  }

  /* Shop Section */
  .shop-section {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
    background: var(--bg-secondary);
  }

  /* About Section */
  .about-section {
    padding: 120px 0;
    background: var(--bg-primary);
  }
  
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 80px;
  }
  
  @media (max-width: 900px) {
    .about-section {
      padding: 60px 0;
    }
    .about-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .about-visual { order: -1; }
    .about-img-tag {
      left: 12px;
      bottom: -12px;
      padding: 8px 14px;
    }
  }

  .about-title {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.12;
    margin: 12px 0 20px;
    letter-spacing: -0.5px;
  }

  @media (max-width: 600px) {
    .about-title { font-size: 2rem; }
  }

  .about-lead {
    font-size: 1.05rem;
    color: var(--text-primary);
    line-height: 1.75;
    font-weight: 500;
    margin-bottom: 14px;
  }

  .about-body {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 40px;
  }

  /* Value Pillars */
  .about-pillars {
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-top: 1px solid var(--card-border);
    padding-top: 32px;
  }

  .pillar {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .pillar-icon {
    width: 42px;
    height: 42px;
    border-radius: 10px;
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--text-primary);
  }

  .pillar-title {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    display: block;
    margin-bottom: 3px;
  }

  .pillar-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* About visual */
  .about-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }
  
  .about-img-box {
    border: 1px solid var(--card-border);
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 0.9;
    width: 100%;
    background: var(--bg-secondary);
    box-shadow: 0 24px 64px rgba(0,0,0,0.07);
  }
  
  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-img-tag {
    position: absolute;
    bottom: -18px;
    left: 24px;
    background: var(--bg-secondary);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 12px 18px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .about-img-tag span {
    font-size: 0.75rem;
    color: #f59e0b;
    letter-spacing: 2px;
  }

  .about-img-tag p {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  /* CTA Section */
  .cta-section {
    background: var(--bg-primary);
    border-top: 1px solid var(--card-border);
    padding: 80px 0;
  }

  .cta-box {
    background: #10044E;
    background: radial-gradient(circle at top left, #A33E5B 0%, #10044E 35%);
    border-radius: 24px;
    padding: 60px 64px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
    border: 1px solid rgba(163, 62, 91, 0.35);
    box-shadow: 0 15px 45px rgba(0, 0, 0, 0.15), inset 0 1px 1px rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .cta-box:hover {
    border-color: rgba(163, 62, 91, 0.55);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2), inset 0 1px 1px rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  @media (max-width: 860px) {
    .cta-box {
      grid-template-columns: 1fr;
      gap: 36px;
      padding: 48px 32px;
    }
  }

  .cta-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 16px;
  }

  .cta-title {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    font-weight: 800;
    color: #ffffff;
    line-height: 1.1;
    letter-spacing: -0.5px;
    margin-bottom: 24px;
  }

  @media (max-width: 600px) {
    .cta-section {
      padding: 40px 0;
    }
    .cta-box {
      padding: 48px 32px;
      border-radius: 20px;
      gap: 28px;
    }
    .cta-title { 
      font-size: 2rem; 
      line-height: 1.2;
    }
    .cta-text { 
      margin-bottom: 24px; 
      font-size: 0.92rem;
      line-height: 1.6;
    }
    .cta-actions {
      display: flex;
      flex-direction: column;
      width: 100%;
      gap: 12px;
    }
    .cta-btn-primary {
      width: 100%;
      justify-content: center;
    }
  }

  .cta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cta-chip {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.8);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: 99px;
    letter-spacing: 0.2px;
  }

  .cta-text {
    color: rgba(255,255,255,0.6);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 32px;
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #F1E6D3;
    color: #0a0a0a;
    padding: 14px 28px;
    border-radius: 99px;
