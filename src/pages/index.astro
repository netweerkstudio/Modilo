---
import '../style.css';
import ProductGrid from '../components/ProductGrid.vue';
import Navbar from '../components/Navbar.astro';
import logoImg from '../assets/logo-transparent.png';
import heroBgImg from '../assets/hero_men_tshirts.png';
import philosophyBgImg from '../assets/philosophy_bg.png';
---

<!DOCTYPE html> 
<html lang="fr">  
  <head>
    <meta charset="UTF-8" /> 
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modilo - Vestiaire Masculin de Caractère</title>
    <meta name="description" content="Sweats à capuche lourds premium, t-shirts d'exception et accessoires exclusifs. Conçus exclusivement pour l'homme d'action." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar activePage="home" isTransparentOnScroll={true} />

    <!-- Hero Section -->
    <section class="hero-section" style={`background-image: url('${heroBgImg.src || heroBgImg}')`}>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="hero-badge">Collection Été 2026</span>
        <h1 class="hero-title">L'Essentiel Élevé <br/>Pour Le Vestiaire Masculin</h1>
        <p class="hero-subtitle">
          Vêtements lourds d'exception et pièces d'ingénierie urbaine pour homme. Conçus pour affirmer votre prestance et durer toute une vie.
        </p>
        <div class="hero-actions">
          <a href="/products" class="btn-primary">Découvrir la Collection</a>
        </div>
      </div>
    </section>

    <!-- Shop Section (Vue Component hydrated dynamically) -->
    <section id="shop" class="shop-section">
      <ProductGrid client:load showOnlyFeatured={true} />
    </section>

    <!-- About Section -->
    <section id="about" class="about-section">
      <div class="container">
        <div class="about-grid">
          <div class="about-text">
            <span class="section-subtitle">Notre Philosophie</span>
            <h2 class="section-title">L'Essence du Vestiaire Masculin.</h2>
            <div class="header-line left-align"></div>
            <p>
              Modilo a été fondé par trois jeunes ambitieux. Nous concevons, cousons et imprimons chaque vêtement avec amour pour vous offrir des pièces uniques et durables.
            </p>
            <p>
              En proposant nos créations directement via WhatsApp, nous maintenons une relation de confiance, de proximité et ultra-réactive avec notre communauté.
            </p>
          </div>
          
          <div class="about-visual">
            <div class="about-glow"></div>
            <div class="about-img-box">
              <img src={philosophyBgImg.src || philosophyBgImg} alt="Artisanat Modilo" class="about-image" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer Section -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <img src={logoImg.src} alt="Modilo Logo" class="footer-logo" />
            <p class="footer-desc">Vêtements de caractère et accessoires urbains haut de gamme, conçus exclusivement pour l'homme.</p>
          </div>
          
          <div class="footer-links">
            <h4>Liens Rapides</h4>
            <a href="/products">Boutique</a>
            <a href="#about">À propos</a>
          </div>
          
          <div class="footer-contact">
            <h4>Contact Direct</h4>
            <p>N'hésitez pas à nous contacter pour toute question, idée ou retour. Nous sommes toujours à l'écoute.</p>
            <a href="https://wa.me/+212630257293" target="_blank" class="footer-whatsapp">
              Discuter sur WhatsApp
            </a>
          </div>
        </div>
        
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Modilo. Tous droits réservés.</p>
          <div class="footer-meta-links">
            <a href="#">Politique de Confidentialité</a>
            <a href="#">Conditions d'Utilisation</a>
          </div>
        </div> 
      </div> 
    </footer>
  </body>
</html>

<style>


  /* Hero Section */
  .hero-section {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 120px 20px 80px;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 12, 0.62) 0%,
      rgba(10, 10, 12, 0.78) 100%
    );
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 780px;
  }

  .hero-badge {
    background: rgba(16,4,78,0.15);
    border: 1px solid rgba(16,4,78,0.35);
    color: rgba(255,255,255,0.9);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    padding: 8px 18px;
    border-radius: 99px;
    margin-bottom: 28px;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -1.5px;
    margin-bottom: 24px;
    color: #ffffff;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 3rem;
    }
  }

  @media (max-width: 600px) {
    .hero-title {
      font-size: 2.3rem;
    }
  }

  .hero-subtitle {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.68);
    margin-bottom: 42px;
    max-width: 560px;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary, .btn-secondary {
    display: inline-block;
    padding: 15px 32px;
    border-radius: 99px;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: all 0.2s ease;
    font-size: 0.95rem;
  }

  .btn-primary {
    background-color: #F1E6D3;
    color: #10044E;
    font-weight: 700;
  }

  .btn-primary:hover {
    background-color: #e8d8c0;
  }

  .btn-secondary {
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: #ffffff;
  }

  .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* Container utility */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Section Intro Headers */
  .section-intro {
    text-align: center;
    margin-bottom: 60px;
  }
  
  .section-subtitle {
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 3px;
    color: var(--text-secondary);
    font-weight: 600;
    display: block;
    margin-bottom: 10px;
  }
  
  .section-title {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  
  .header-line {
    width: 50px;
    height: 3px;
    background: linear-gradient(90deg, #10044E, #3b1fa8);
    margin: 15px auto 0;
    border-radius: 99px;
  }
  
  .header-line.left-align {
    margin: 15px 0 0;
  }

  /* Categories Grid Section */
  .categories-section {
    padding: 100px 0;
    position: relative;
    z-index: 1;
  }
  
  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
  }
  
  .category-card {
    position: relative;
    height: 350px;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 30px;
    text-decoration: none;
    color: var(--text-primary);
    border: 1px solid var(--card-border);
    background: var(--bg-secondary);
    transition: border-color 0.2s, transform 0.2s;
  }
  
  .category-bg {
    position: absolute;
    inset: 0;
    background: var(--bg-primary);
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 0;
  }
  
  .category-card:hover .category-bg {
    opacity: 1;
  }
  
  .category-img {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 60%;
    height: auto;
    object-fit: contain;
    transition: transform 0.2s;
    opacity: 0.9;
    z-index: 1;
  }
  
  .category-card:hover {
    border-color: var(--accent-indigo);
    box-shadow: 0 8px 32px rgba(16,4,78,0.10);
    transform: translateY(-3px);
  }
  
  .category-card:hover .category-img {
    transform: scale(1.03);
  }
  
  .category-content {
    position: relative;
    z-index: 2;
  }
  
  .category-tagline {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
    display: block;
    margin-bottom: 6px;
    font-weight: 500;
  }
  
  .category-name {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 12px;
  }
  
  .category-link-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-secondary);
    transition: color 0.2s;
    display: inline-block;
  }
  
  .category-card:hover .category-link-text {
    color: var(--accent-primary);
  }

  /* Shop Section */
  .shop-section {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
    background: var(--bg-secondary);
  }

  /* About Section */
  .about-section {
    padding: 120px 0;
    position: relative;
    z-index: 1;
  }
  
  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: 80px;
  }
  
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 50px;
    }
  }
  
  .about-text p {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.05rem;
    margin-top: 25px;
  }
  
  .about-stats {
    display: flex;
    gap: 40px;
    margin-top: 40px;
    flex-wrap: wrap;
  }
  
  .stat-item {
    display: flex;
    flex-direction: column;
  }
  
  .stat-number {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-primary);
  }
  
  .stat-label {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
    font-weight: 600;
  }
  
  .about-visual {
    position: relative;
    display: flex;
    justify-content: center;
  }
  
  .about-glow {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(16,4,78,0.12) 0%, rgba(16,4,78,0.04) 60%, transparent 100%);
    z-index: 0;
  }
  
  .about-img-box {
    border: 1px solid var(--card-border);
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 1.25;
    position: relative;
    z-index: 1;
    background: var(--bg-secondary);
  }
  
  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }

  /* Footer */
  .footer {
    background-color: var(--bg-secondary);
    border-top: 1px solid var(--card-border);
    padding: 80px 0 40px;
    position: relative;
    z-index: 1;
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 60px;
    margin-bottom: 60px;
  }
  
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .footer-logo {
    height: 45px;
    width: fit-content;
    object-fit: contain;
  }
  
  .footer-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    max-width: 320px;
  }
  
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  
  .footer-links h4, .footer-contact h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 5px;
    color: var(--text-primary);
  }
  
  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.3s;
  }
  
  .footer-links a:hover {
    color: var(--text-primary);
  }
  
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  
  .footer-contact p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }
  
  .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    background: linear-gradient(135deg, #10044E, #3b1fa8);
    color: #ffffff;
    text-decoration: none;
    font-weight: 700;
    padding: 12px 24px;
    border-radius: 99px;
    font-size: 0.9rem;
    transition: all 0.3s;
    box-shadow: 0 4px 14px rgba(16,4,78,0.25);
  }
  
  .footer-whatsapp:hover {
    background: linear-gradient(135deg, #0d0340, #10044E);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(16,4,78,0.35);
  }
  
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
  }
  
  .footer-bottom p {
    color: var(--text-muted);
    font-size: 0.85rem;
  }
  
  .footer-meta-links {
    display: flex;
    gap: 20px;
  }
  
  .footer-meta-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.3s;
  }
  
  .footer-meta-links a:hover {
    color: var(--text-secondary);
  }
</style>
