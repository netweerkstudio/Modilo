---
import '../style.css';
import ProductGrid from '../components/ProductGrid.vue';
import Navbar from '../components/Navbar.astro';
import logoImg from '../assets/logo-transparent.png';
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modilo - Boutique & Vestiaire Complet</title>
    <meta name="description" content="Explorez l'intégralité de nos pièces d'exception. Sweats lourds, t-shirts de caractère et accessoires exclusifs pour l'homme d'action." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar activePage="products" />

    <!-- Intro Header -->
    <section class="products-intro">
      <div class="container">
        <div class="section-intro">
          <span class="section-subtitle">Collection Modilo</span>
          <h1 class="page-title">Notre Vestiaire</h1>
          <div class="header-line"></div>
        </div>
      </div>
    </section>

    <!-- Filterable Product Grid Section -->
    <section class="shop-section">
      <ProductGrid client:load showOnlyFeatured={false} />
    </section>

    <!-- Footer Section -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <img src={logoImg.src} alt="Modilo Logo" class="footer-logo" />
            <p class="footer-desc">Vêtements de caractère et accessoires urbains haut de gamme, conçus exclusivement pour l'homme.</p>
          </div>
          
          <div class="footer-links">
            <h4>Liens Rapides</h4>
            <a href="/products">Boutique</a>
            <a href="/#about">À propos</a>
          </div>
          
          <div class="footer-contact">
            <h4>Contact Direct</h4>
            <p>N'hésitez pas à nous contacter pour toute question, idée ou retour. Nous sommes toujours à l'écoute.</p>
            <a href="https://wa.me/+212630257293" target="_blank" class="footer-whatsapp">
              Discuter sur WhatsApp
            </a>
          </div>
        </div>
        
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Modilo. Tous droits réservés.</p>
          <div class="footer-meta-links">
            <a href="#">Politique de Confidentialité</a>
            <a href="#">Conditions d'Utilisation</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>


  /* Intro Section */
  .products-intro {
    padding: 140px 0 40px;
    background: var(--bg-primary);
  }

  .section-intro {
    text-align: center;
  }

  .section-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
    font-weight: 600;
    display: block;
    margin-bottom: 12px;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 15px;
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: var(--text-primary);
    margin: 0 auto;
  }

  /* Shop Section */
  .shop-section {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
    background: var(--bg-secondary);
    padding: 60px 0 100px;
  }

  /* Container utility */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Footer Styles */
  .footer {
    background: var(--bg-primary);
    padding: 80px 0 40px;
    border-top: 1px solid var(--card-border);
    color: var(--text-primary);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 60px;
    margin-bottom: 60px;
  }
  
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  
  .footer-logo {
    height: 40px;
    object-fit: contain;
    margin-bottom: 20px;
  }
  
  .footer-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  
  .footer-links h4, .footer-contact h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 20px;
  }
  
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  
  .footer-links a:hover {
    color: var(--text-primary);
  }
  
  .footer-contact p {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 20px;
  }
  
  .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    background: linear-gradient(135deg, #10044E, #3b1fa8);
    color: #ffffff;
    padding: 12px 24px;
    border-radius: 99px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
    box-shadow: 0 4px 14px rgba(16,4,78,0.25);
  }
  
  .footer-whatsapp:hover {
    background: linear-gradient(135deg, #0d0340, #10044E);
    box-shadow: 0 6px 20px rgba(16,4,78,0.35);
    transform: translateY(-1px);
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--card-border);
    padding-top: 30px;
    color: var(--text-secondary);
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 15px;
  }
  
  .footer-meta-links {
    display: flex;
    gap: 20px;
  }
  
  .footer-meta-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .footer-meta-links a:hover {
    color: var(--text-primary);
  }
</style>
