---
import '../style.css';
import ProductGrid from '../components/ProductGrid.vue';
import logoImg from '../assets/logo-transparent.png';
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modilo - Boutique & Vestiaire Complet</title>
    <meta name="description" content="Explorez l'intégralité de nos pièces d'exception. Sweats lourds, t-shirts de caractère et accessoires exclusifs pour l'homme d'action." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- Header Navigation -->
    <header class="header">
      <div class="header-container">
        <a href="/" class="logo-link">
          <img src={logoImg.src} alt="Modilo Logo" class="nav-logo" />
        </a>
        
        <nav class="nav-menu">
          <a href="/products" class="nav-link active">Boutique</a>
          <a href="/categories" class="nav-link">Catégories</a>
          <a href="/#about" class="nav-link">À propos</a>
        </nav>
        
        <div class="nav-actions">
          <a href="https://wa.me/+212630257293" target="_blank" class="contact-btn">
            <span>Support WhatsApp</span>
            <svg viewBox="0 0 24 24" width="16" height="16">
              <path fill="currentColor" d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.233-1.371a9.936 9.936 0 0 0 4.779 1.21h.005c5.505 0 9.988-4.479 9.989-9.986 0-2.67-1.037-5.178-2.922-7.062A9.925 9.925 0 0 0 12.012 2zm5.835 14.165c-.32.9-.1.9-.1.9s-.427 1.099-1.637 1.328c-1.21.23-2.56.096-4.576-.718-2.016-.814-3.526-2.585-4.464-3.878-.938-1.293-1.579-2.738-1.579-4.22 0-1.48.718-2.203 1.026-2.502.308-.299.82-.455 1.077-.455.257 0 .492-.01.705.01.214.02.487-.08.761.564.274.645.94 2.274 1.017 2.43.077.157.12.338.017.532-.102.193-.154.314-.308.492-.154.177-.325.298-.462.46-.153.18-.316.378-.137.684.18.307.8 1.314 1.718 2.128.918.814 1.692 1.065 1.992 1.185.3.12.478.105.658-.1.18-.206.77-.895.974-1.2.206-.307.41-.258.693-.153.282.105 1.795.847 2.103.992.308.145.513.218.59.35.077.133.077.77-.243 1.67z"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <!-- Intro Header -->
    <section class="products-intro">
      <div class="container">
        <div class="section-intro">
          <span class="section-subtitle">Collection Modilo</span>
          <h1 class="page-title">Notre Vestiaire</h1>
          <div class="header-line"></div>
        </div>
      </div>
    </section>

    <!-- Filterable Product Grid Section -->
    <section class="shop-section">
      <ProductGrid client:load showOnlyFeatured={false} />
    </section>

    <!-- Footer Section -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <img src={logoImg.src} alt="Modilo Logo" class="footer-logo" />
            <p class="footer-desc">Vêtements de caractère et accessoires urbains haut de gamme, conçus exclusivement pour l'homme.</p>
          </div>
          
          <div class="footer-links">
            <h4>Liens Rapides</h4>
            <a href="/products">Boutique</a>
            <a href="/categories">Catégories</a>
            <a href="/#about">À propos</a>
          </div>
          
          <div class="footer-contact">
            <h4>Contact Direct</h4>
            <p>N'hésitez pas à nous contacter pour toute question, idée ou retour. Nous sommes toujours à l'écoute.</p>
            <a href="https://wa.me/+212630257293" target="_blank" class="footer-whatsapp">
              Discuter sur WhatsApp
            </a>
          </div>
        </div>
        
        <div class="footer-bottom">
          <p>&copy; {new Date().getFullYear()} Modilo. Tous droits réservés.</p>
          <div class="footer-meta-links">
            <a href="#">Politique de Confidentialité</a>
            <a href="#">Conditions d'Utilisation</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Header Styles */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    z-index: 1000;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--card-border);
    transition: all 0.3s ease;
  }
  
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .logo-link {
    display: flex;
    align-items: center;
  }
  
  .nav-logo {
    height: 40px;
    object-fit: contain;
  }
  
  .nav-menu {
    display: flex;
    gap: 30px;
  }
  
  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  
  .nav-link:hover, .nav-link.active {
    color: var(--text-primary);
  }
  
  .contact-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg-primary);
    border: 1px solid var(--card-border);
    color: var(--text-primary);
    padding: 10px 20px;
    border-radius: 99px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  
  .contact-btn:hover {
    background: var(--text-primary);
    color: var(--bg-secondary);
    border-color: var(--text-primary);
  }

  /* Intro Section */
  .products-intro {
    padding: 140px 0 40px;
    background: var(--bg-primary);
  }

  .section-intro {
    text-align: center;
  }

  .section-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
    font-weight: 600;
    display: block;
    margin-bottom: 12px;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 15px;
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: var(--text-primary);
    margin: 0 auto;
  }

  /* Shop Section */
  .shop-section {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
    background: var(--bg-secondary);
    padding: 60px 0 100px;
  }

  /* Container utility */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Footer Styles */
  .footer {
    background: var(--bg-primary);
    padding: 80px 0 40px;
    border-top: 1px solid var(--card-border);
    color: var(--text-primary);
  }
  
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 60px;
    margin-bottom: 60px;
  }
  
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  
  .footer-logo {
    height: 40px;
    object-fit: contain;
    margin-bottom: 20px;
  }
  
  .footer-desc {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
  }
  
  .footer-links h4, .footer-contact h4 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 20px;
  }
  
  .footer-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  
  .footer-links a:hover {
    color: var(--text-primary);
  }
  
  .footer-contact p {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.95rem;
    margin-bottom: 20px;
  }
  
  .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    background: var(--text-primary);
    color: var(--bg-secondary);
    padding: 12px 24px;
    border-radius: 99px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s;
  }
  
  .footer-whatsapp:hover {
    background: var(--text-secondary);
  }
  
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--card-border);
    padding-top: 30px;
    color: var(--text-secondary);
    font-size: 0.85rem;
    flex-wrap: wrap;
    gap: 15px;
  }
  
  .footer-meta-links {
    display: flex;
    gap: 20px;
  }
  
  .footer-meta-links a {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }
  
  .footer-meta-links a:hover {
    color: var(--text-primary);
  }
</style>
