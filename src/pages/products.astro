---
import '../style.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProductGrid from '../components/ProductGrid.vue';
---

<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Modilo - Boutique & Vestiaire Complet</title>
    <meta name="description" content="Explorez l'intégralité de nos pièces d'exception. Sweats lourds, t-shirts de caractère et accessoires exclusifs pour l'homme d'action." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar activePage="products" />

    <!-- Intro Header -->
    <section class="products-intro">
      <div class="container">
        <div class="section-intro">
          <span class="section-subtitle">Collection Modilo</span>
          <h1 class="page-title">Notre Vestiaire</h1>
          <div class="header-line"></div>
        </div>
      </div>
    </section>

    <!-- Filterable Product Grid Section -->
    <section class="shop-section">
      <ProductGrid client:load showOnlyFeatured={false} />
    </section>

    <Footer />
  </body>
</html>

<style>


  /* Intro Section */
  .products-intro {
    padding: 140px 0 40px;
    background: var(--bg-primary);
  }

  .section-intro {
    text-align: center;
  }

  .section-subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--text-secondary);
    font-weight: 600;
    display: block;
    margin-bottom: 12px;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 15px;
  }

  .header-line {
    width: 60px;
    height: 2px;
    background: var(--text-primary);
    margin: 0 auto;
  }

  /* Shop Section */
  .shop-section {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--card-border);
    border-bottom: 1px solid var(--card-border);
    background: var(--bg-secondary);
    padding: 60px 0 100px;
  }

  /* Container utility */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }


</style>
