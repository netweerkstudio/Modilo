    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Modilo. Tous droits réservés.</p>
      <p class="developed-by">
        Développé par <a href="https://netweerk.studio" target="_blank" rel="noopener noreferrer">netweerk.studio</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #0a0a0a;
    background: linear-gradient(180deg, #0a0a0a 0%, #050212 100%);
    color: #ffffff;
    padding: 90px 0 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: 64px;
    margin-bottom: 60px;
  }

  @media (max-width: 868px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      margin-bottom: 48px;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  .footer-logo {
    height: 36px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  .footer-desc {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.92rem;
    line-height: 1.65;
    max-width: 340px;
    margin: 0;
  }

  .footer-links h4,
  .footer-contact h4 {
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: #ffffff;
    margin: 0 0 24px 0;
  }

  .links-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .links-list a {
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    font-size: 0.92rem;
    font-weight: 500;
    transition: all 0.25s ease;
    align-self: flex-start;
  }

  .links-list a:hover {
    color: #F1E6D3;
    transform: translateX(4px);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: flex-start;
  }

  .footer-contact p {
    color: rgba(255, 255, 255, 0.55);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(37, 211, 102, 0.05);
    border: 1px solid rgba(37, 211, 102, 0.25);
    color: #25d366;
    padding: 12px 24px;
    border-radius: 99px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .footer-whatsapp:hover {
    background: #25d366;
    color: #ffffff;
    border-color: #25d366;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(37, 211, 102, 0.25);
  }

  /* Bottom Area */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.82rem;
    margin: 0;
  }

  .developed-by a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .developed-by a:hover {
    color: #ffffff;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
  }

  .footer-socials {
    display: flex;
    gap: 12px;
    margin-top: 20px;
  }

  .social-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.65);
    transition: all 0.25s ease;
    text-decoration: none;
  }

  .social-icon-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #F1E6D3;
    border-color: rgba(241, 230, 211, 0.35);
    transform: translateY(-2px);
  }

  .social-icon-btn[aria-label="Instagram"]:hover {
    color: #e1306c;
    border-color: rgba(225, 48, 108, 0.35);
    background: rgba(225, 48, 108, 0.08);
  }

  .social-icon-btn[aria-label="Facebook"]:hover {
    color: #1877f2;
    border-color: rgba(24, 119, 242, 0.35);
    background: rgba(24, 119, 242, 0.08);
  }

  .social-icon-btn[aria-label="WhatsApp"]:hover {
    color: #25d366;
    border-color: rgba(37, 211, 102, 0.35);
    background: rgba(37, 211, 102, 0.08);
  }

  @media (max-width: 600px) {
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      padding-top: 24px;
    }
  }
</style>
