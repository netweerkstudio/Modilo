---
import logoImg from '../assets/logo-transparent.png';

interface Props {
  activePage?: string;
  isTransparentOnScroll?: boolean;
}

const { activePage = 'home', isTransparentOnScroll = false } = Astro.props;
---

<header class={`header ${isTransparentOnScroll ? 'transparent-header' : 'solid-header'}`}>
  <div class="header-container">
    <a href="/" class="logo-link">
      <img src={logoImg.src} alt="Modilo Logo" class="nav-logo" />
    </a>
    
    <nav class="nav-menu">
      <a href="/" class={`nav-link ${activePage === 'home' ? 'active' : ''}`}>Accueil</a>
      <a href="/products" class={`nav-link ${activePage === 'products' ? 'active' : ''}`}>Boutique</a>
      <a href="/custom" class={`nav-link ${activePage === 'custom' ? 'active' : ''}`}>Impression Perso</a>
      <a href="/delivery" class={`nav-link ${activePage === 'delivery' ? 'active' : ''}`}>Livraison</a>
    </nav>
    
    <div class="nav-actions">
      <a href="/cart" class={`nav-cart-btn ${activePage === 'cart' ? 'active' : ''}`} aria-label="Mon Panier">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="nav-cart-count">0</span>
      </a>
      
      {activePage === 'custom' ? (
        <a href="https://wa.me/+212630257293" target="_blank" class="contact-btn">
          <span>Support WhatsApp</span>
          <svg viewBox="0 0 24 24" width="16" height="16">
            <path fill="currentColor" d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.233-1.371a9.936 9.936 0 0 0 4.779 1.21h.005c5.505 0 9.988-4.479 9.989-9.986 0-2.67-1.037-5.178-2.922-7.062A9.925 9.925 0 0 0 12.012 2zm5.835 14.165c-.32.9-.1.9-.1.9s-.427 1.099-1.637 1.328c-1.21.23-2.56.096-4.576-.718-2.016-.814-3.526-2.585-4.464-3.878-.938-1.293-1.579-2.738-1.579-4.22 0-1.48.718-2.203 1.026-2.502.308-.299.82-.455 1.077-.455.257 0 .492-.01.705.01.214.02.487-.08.761.564.274.645.94 2.274 1.017 2.43.077.157.12.338.017.532-.102.193-.154.314-.308.492-.154.177-.325.298-.462.46-.153.18-.316.378-.137.684.18.307.8 1.314 1.718 2.128.918.814 1.692 1.065 1.992 1.185.3.12.478.105.658-.1.18-.206.77-.895.974-1.2.206-.307.41-.258.693-.153.282.105 1.795.847 2.103.992.308.145.513.218.59.35.077.133.077.77-.243 1.67z"/>
          </svg>
        </a>
      ) : activePage === 'delivery' ? (
        <a href="https://wa.me/+212630257293" target="_blank" class="contact-btn">
          <span>Support WhatsApp</span>
          <svg viewBox="0 0 24 24" width="16" height="16">
            <path fill="currentColor" d="M12.012 2c-5.506 0-9.989 4.478-9.99 9.984a9.96 9.96 0 0 0 1.333 4.982L2 22l5.233-1.371a9.936 9.936 0 0 0 4.779 1.21h.005c5.505 0 9.988-4.479 9.989-9.986 0-2.67-1.037-5.178-2.922-7.062A9.925 9.925 0 0 0 12.012 2zm5.835 14.165c-.32.9-.1.9-.1.9s-.427 1.099-1.637 1.328c-1.21.23-2.56.096-4.576-.718-2.016-.814-3.526-2.585-4.464-3.878-.938-1.293-1.579-2.738-1.579-4.22 0-1.48.718-2.203 1.026-2.502.308-.299.82-.455 1.077-.455.257 0 .492-.01.705.01.214.02.487-.08.761.564.274.645.94 2.274 1.017 2.43.077.157.12.338.017.532-.102.193-.154.314-.308.492-.154.177-.325.298-.462.46-.153.18-.316.378-.137.684.18.307.8 1.314 1.718 2.128.918.814 1.692 1.065 1.992 1.185.3.12.478.105.658-.1.18-.206.77-.895.974-1.2.206-.307.41-.258.693-.153.282.105 1.795.847 2.103.992.308.145.513.218.59.35.077.133.077.77-.243 1.67z"/>
          </svg>
        </a>
      ) : (
        <a href="/custom" class="contact-btn">
          <span>Impression Perso</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="14 2 14 8 20 8"></polyline>
            <path d="M20 2H4a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8z"></path>
            <line x1="12" y1="12" x2="12" y2="18"></line>
            <line x1="9" y1="15" x2="15" y2="15"></line>
          </svg>
        </a>
      )}
    </div>
  </div>
</header>

<script is:inline define:vars={{ isTransparentOnScroll }}>
  // Scroll handler for transparent hero navbar
  if (isTransparentOnScroll) {
    window.addEventListener('scroll', () => {
      const header = document.querySelector('.header');
      if (window.scrollY > 20) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });
  }



  function updateNavCartBadge() {
    try {
      const saved = localStorage.getItem('modilo_cart');
      const cart = saved ? JSON.parse(saved) : [];
      const count = cart.reduce((total, item) => total + item.quantity, 0);
      const badges = document.querySelectorAll('.nav-cart-count');
      badges.forEach(b => {
        b.textContent = count;
        if (count > 0) {
          b.classList.add('has-items');
        } else {
          b.classList.remove('has-items');
        }
      });
    } catch (e) {
      console.error(e);
    }
  }

  document.addEventListener('DOMContentLoaded', updateNavCartBadge);
  window.addEventListener('cart-updated', updateNavCartBadge);
</script>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    z-index: 1000;
    transition: all 0.3s ease;
  }

  .solid-header {
    background: #000000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .transparent-header {
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  .transparent-header.scrolled {
    background: #000000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .logo-link {
    display: flex;
    align-items: center;
  }
  
  .nav-logo {
    height: 64px;
    object-fit: contain;
  }
  
  .nav-menu {
    display: flex;
    gap: 30px;
  }
  
  .nav-link {
    color: #F1E6D3;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }
  
  .nav-link:hover, .nav-link.active {
    color: #ffffff;
  }
  
  .contact-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #F1E6D3;
    border: 1px solid #F1E6D3;
    color: #10044E;
    padding: 10px 20px;
    border-radius: 99px;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 700;
    transition: all 0.2s;
  }
  
  .contact-btn:hover {
    background: #10044E;
    color: #F1E6D3;
    border-color: #10044E;
  }

  /* Specific color for custom & delivery pages on hover */
  .solid-header .contact-btn:hover {
    color: #ffffff;
  }
  
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .nav-cart-btn {
    background: transparent;
    border: none;
    color: #F1E6D3;
    cursor: pointer;
    position: relative;
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .nav-cart-btn:hover {
    color: #ffffff;
  }

  .nav-cart-count {
    position: absolute;
    top: -2px;
    right: -2px;
    background: #ffffff;
    color: #000000;
    border: 1.5px solid #000000;
    font-size: 0.7rem;
    font-weight: 700;
    min-width: 18px;
    height: 18px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.2s ease;
  }

  .nav-cart-count.has-items {
    opacity: 1;
    transform: scale(1);
  }
</style>
