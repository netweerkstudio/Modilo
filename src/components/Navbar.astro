---
import logoImg from '../assets/images/logo/logo-website.png';

interface Props {
  activePage?: string;
  isTransparentOnScroll?: boolean;
}

const { activePage = 'home', isTransparentOnScroll = false } = Astro.props;
---

<header class={`header ${isTransparentOnScroll ? 'transparent-header' : 'solid-header'}`}>
  <div class="header-container">
    <a href="/" class="logo-link">
      <img src={logoImg.src} alt="Modilo Logo" class="nav-logo" />
    </a> 
    
    <nav class="nav-menu">
      <a href="/" class={`nav-link ${activePage === 'home' ? 'active' : ''}`}>Accueil</a>
      <a href="/products" class={`nav-link ${activePage === 'products' ? 'active' : ''}`}>Boutique</a>
      <a href="/custom" class={`nav-link ${activePage === 'custom' ? 'active' : ''}`}>Design Perso</a>
      <a href="/delivery" class={`nav-link ${activePage === 'delivery' ? 'active' : ''}`}>Livraison</a>
    </nav>
    
    <div class="nav-actions">
      <a href="https://wa.me/+212630257293?text=Bonjour%20Modilo%2C%20je%20souhaite%20lancer%20un%20projet%20de%20design%20personnalis%C3%A9." target="_blank" class="nav-wa-btn" aria-label="WhatsApp Modilo">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.705 1.459h.006c6.56 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
      </a>
      <a href="/cart" class={`nav-cart-btn ${activePage === 'cart' ? 'active' : ''}`} aria-label="Mon Panier">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="nav-cart-count">0</span>
      </a>
      
      <button class="mobile-menu-toggle" aria-label="Menu" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12" class="line-middle"></line>
          <line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
          <line x1="3" y1="18" x2="21" y2="18" class="line-bottom"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<script is:inline define:vars={{ isTransparentOnScroll }}>
  if (isTransparentOnScroll) {
    window.addEventListener('scroll', () => {
      const header = document.querySelector('.header');
      if (header && window.scrollY > 20) {
        header.classList.add('scrolled');
      } else if (header) {
        header.classList.remove('scrolled');
      }
    });
  }

  function updateNavCartBadge() {
    try {
      const saved = localStorage.getItem('modilo_cart');
      const cart = saved ? JSON.parse(saved) : [];
      const count = cart.reduce((total, item) => total + item.quantity, 0);
      const badges = document.querySelectorAll('.nav-cart-count');
      badges.forEach(b => {
        b.textContent = count;
        if (count > 0) {
          b.classList.add('has-items');
        } else {
          b.classList.remove('has-items');
        }
      });
    } catch (e) {
      console.error(e);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateNavCartBadge();

    const toggleBtn = document.querySelector('.mobile-menu-toggle');
    const navMenu = document.querySelector('.nav-menu');
    const header = document.querySelector('.header');

    if (toggleBtn && navMenu && header) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = toggleBtn.classList.toggle('open');
        navMenu.classList.toggle('active');
        header.classList.toggle('menu-open');
        toggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });
    }
  });

  window.addEventListener('cart-updated', updateNavCartBadge);
</script>

<style>
  .header {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 1160px;
    z-index: 1000;
    border-radius: 16px;
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease, border-radius 0.3s ease;
  }

  .solid-header {
    background: rgba(10, 10, 10, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .transparent-header {
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
  }

  .transparent-header.scrolled {
    background: rgba(10, 10, 10, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  
  .header-container {
    padding: 16px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .logo-link {
    display: flex;
    align-items: center;
  }
  
  .nav-logo {
    height: 52px;
    object-fit: contain;
  }
  
  .nav-menu {
    display: flex;
    gap: 28px;
  }
  
  .nav-link {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
    letter-spacing: 0.2px;
    position: relative;
    padding: 6px 0;
  }
  
  .nav-link:hover {
    color: #ffffff;
  }

  .nav-link.active {
    color: #F1E6D3;
    font-weight: 600;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #F1E6D3;
    transition: width 0.25s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link.active::after {
    width: 100%;
  }
  
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-cart-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.72);
    cursor: pointer;
    position: relative;
    padding: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    text-decoration: none;
  }

  .nav-cart-btn:hover {
    color: #ffffff;
  }

  .nav-wa-btn {
    background: rgba(37, 211, 102, 0.08);
    border: 1px solid rgba(37, 211, 102, 0.2);
    color: #25d366;
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .nav-wa-btn:hover {
    background: #25d366;
    color: #ffffff;
    border-color: #25d366;
    transform: scale(1.05);
    box-shadow: 0 0 12px rgba(37, 211, 102, 0.35);
  }

  .nav-cart-count {
    position: absolute;
    top: -2px;
    right: -2px;
    background: #ffffff;
    color: #000000;
    border: 1.5px solid rgba(0,0,0,0.15);
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 17px;
    height: 17px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    opacity: 0;
    transform: scale(0.7);
    transition: all 0.2s ease;
  }

  .nav-cart-count.has-items {
    opacity: 1;
    transform: scale(1);
  }

  .mobile-menu-toggle {
    display: none;
    background: transparent;
    border: none;
    color: #ffffff;
    cursor: pointer;
    padding: 6px;
    align-items: center;
    justify-content: center;
  }

  .mobile-menu-toggle line {
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .mobile-menu-toggle.open .line-middle {
    opacity: 0;
    transform: scale(0);
  }

  .mobile-menu-toggle.open .line-top {
    transform: translateY(6px) rotate(45deg);
  }

  .mobile-menu-toggle.open .line-bottom {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .header {
      top: 12px;
      width: calc(100% - 24px);
      border-radius: 12px;
    }
    
    .header.menu-open {
      border-radius: 12px 12px 0 0;
      background: rgba(10, 10, 10, 0.96);
    }

    .header-container {
      padding: 16px 16px;
    }

    .nav-logo {
      height: 38px;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: rgba(10, 10, 10, 0.96);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: none;
      border-radius: 0 0 12px 12px;
      flex-direction: column;
      gap: 0;
      padding: 8px 16px 20px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 16px 40px rgba(0, 0, 0, 0.4);
    }

    .nav-menu.active {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .nav-link {
      width: 100%;
      padding: 14px 0;
      font-size: 0.95rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      display: flex;
      align-items: center;
      position: relative;
    }

    .nav-link:last-child {
      border-bottom: none;
    }

    .nav-link::after {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .header {
      top: 8px;
      width: calc(100% - 16px);
    }
    
    .nav-logo {
      height: 34px;
    }

    .nav-actions {
      gap: 8px;
    }

    .nav-wa-btn {
      width: 32px;
      height: 32px;
    }

    .nav-wa-btn svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
