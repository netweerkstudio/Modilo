---
import logoImg from '../assets/logo-transparent.png';

interface Props {
  activePage?: string;
  isTransparentOnScroll?: boolean;
}

const { activePage = 'home', isTransparentOnScroll = false } = Astro.props;
---

<header class={`header ${isTransparentOnScroll ? 'transparent-header' : 'solid-header'}`}>
  <div class="header-container">
    <a href="/" class="logo-link">
      <img src={logoImg.src} alt="Modilo Logo" class="nav-logo" />
    </a>
    
    <nav class="nav-menu">
      <a href="/" class={`nav-link ${activePage === 'home' ? 'active' : ''}`}>Accueil</a>
      <a href="/products" class={`nav-link ${activePage === 'products' ? 'active' : ''}`}>Boutique</a>
      <a href="/delivery" class={`nav-link ${activePage === 'delivery' ? 'active' : ''}`}>Livraison</a>
    </nav>
    
    <div class="nav-actions">
      <a href="/cart" class={`nav-cart-btn ${activePage === 'cart' ? 'active' : ''}`} aria-label="Mon Panier">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span class="nav-cart-count">0</span>
      </a>
    </div>
  </div>
</header>

<script is:inline define:vars={{ isTransparentOnScroll }}>
  // Scroll handler for transparent hero navbar
  if (isTransparentOnScroll) {
    window.addEventListener('scroll', () => {
      const header = document.querySelector('.header');
      if (window.scrollY > 20) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    });
  }



  function updateNavCartBadge() {
    try {
      const saved = localStorage.getItem('modilo_cart');
      const cart = saved ? JSON.parse(saved) : [];
      const count = cart.reduce((total, item) => total + item.quantity, 0);
      const badges = document.querySelectorAll('.nav-cart-count');
      badges.forEach(b => {
        b.textContent = count;
        if (count > 0) {
          b.classList.add('has-items');
        } else {
          b.classList.remove('has-items');
        }
      });
    } catch (e) {
      console.error(e);
    }
  }

  document.addEventListener('DOMContentLoaded', updateNavCartBadge);
  window.addEventListener('cart-updated', updateNavCartBadge);
</script>

<style>
  .header {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 40px);
    max-width: 1160px;
    z-index: 1000;
    border-radius: 16px;
    transition: background 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .solid-header {
    background: rgba(10, 10, 10, 0.92);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .transparent-header {
    background: transparent;
    border: 1px solid transparent;
    box-shadow: none;
  }

  .transparent-header.scrolled {
    background: rgba(10, 10, 10, 0.88);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  
  .header-container {
    padding: 12px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  
  .logo-link {
    display: flex;
    align-items: center;
  }
  
  .nav-logo {
    height: 52px;
    object-fit: contain;
  }
  
  .nav-menu {
    display: flex;
    gap: 28px;
  }
  
  .nav-link {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
    letter-spacing: 0.2px;
  }
  
  .nav-link:hover, .nav-link.active {
    color: #ffffff;
  }
  
  .contact-btn {
    display: flex;
    align-items: center;
    gap: 7px;
    background: #F1E6D3;
    border: 1px solid #F1E6D3;
    color: #0a0a0a;
    padding: 9px 18px;
    border-radius: 99px;
    text-decoration: none;
    font-size: 0.82rem;
    font-weight: 700;
    transition: all 0.2s;
    letter-spacing: 0.2px;
  }
  
  .contact-btn:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #0a0a0a;
  }
  
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nav-cart-btn {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.72);
    cursor: pointer;
    position: relative;
    padding: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
    text-decoration: none;
  }

  .nav-cart-btn:hover {
    color: #ffffff;
  }

  .nav-cart-count {
    position: absolute;
    top: -2px;
    right: -2px;
    background: #ffffff;
    color: #000000;
    border: 1.5px solid rgba(0,0,0,0.15);
    font-size: 0.65rem;
    font-weight: 700;
    min-width: 17px;
    height: 17px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    opacity: 0;
    transform: scale(0.7);
    transition: all 0.2s ease;
  }

  .nav-cart-count.has-items {
    opacity: 1;
    transform: scale(1);
  }

  @media (max-width: 768px) {
    .header {
      top: 10px;
      width: calc(100% - 20px);
      border-radius: 12px;
    }
    .header-container {
      padding: 8px 12px;
    }
    .nav-logo {
      height: 38px;
    }
    .nav-menu {
      display: flex;
      gap: 12px;
    }
    .nav-link {
      font-size: 0.78rem;
    }
  }

  @media (max-width: 480px) {
    .nav-menu {
      gap: 8px;
    }
    .nav-link {
      font-size: 0.75rem;
    }
    .nav-logo {
      height: 32px;
    }
  }
</style>
